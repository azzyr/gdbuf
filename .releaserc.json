{
  "branches": [
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "bin/gdbuf-linux-amd64",
            "label": "gdbuf-linux-amd64"
          },
          {
            "path": "bin/gdbuf-darwin-arm64",
            "label": "gdbuf-darwin-arm64"
          }
        ]
      }
    ]
  ]
}
